# ── Lao-tse Records Studio — Environment Variables ──────────────────────────
# Copy this file to .env and fill in the values.

# PostgreSQL — Railway provides this automatically via the Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/laotse_records?sslmode=require

# JSON Web Token secret — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Server port (Railway sets this automatically)
PORT=8080

# Environment
ENV=development
